rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny-all por defecto — cualquier path no listado es inaccesible
    match /{document=**} {
      allow read, write: if false;
    }

    // Campañas: lectura pública (dashboard de cliente), escritura solo via Admin SDK
    match /campaigns/{campaignId}/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
